/*
 * -------------------------------------------------
 *  STAR Alignment Process-Specific Config
 * -------------------------------------------------
 * Resource configurations for STAR alignment processes:
 * - STAR_BUILD_INDEX
 * - STAR_ALIGN
 *
 * Used by: star_alignment.nf
 *
 * Note: These processes set their own resources via pipeline parameters
 * (--star_threads, --star_memory_gb), so these are just fallback defaults.
 */

process {

  withName: STAR_BUILD_INDEX {
    // Resources are set via pipeline params (star_threads, star_memory_gb)
    // These are fallback defaults only
    cpus = { check_max( 16 * task.attempt, 'cpus' ) }
    memory = { check_max( 64.GB * task.attempt, 'memory' ) }
    time = { check_max( 12.h * task.attempt, 'time' ) }
  }

  withName: STAR_ALIGN {
    // Resources are set via pipeline params (star_threads, star_memory_gb)
    // These are fallback defaults only
    cpus = { check_max( 16 * task.attempt, 'cpus' ) }
    memory = { check_max( 64.GB * task.attempt, 'memory' ) }
    time = { check_max( 12.h * task.attempt, 'time' ) }
  }

}
