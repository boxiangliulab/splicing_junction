/*
 * -------------------------------------------------
 *  Junction Analysis Process-Specific Config
 * -------------------------------------------------
 * Resource configurations for junction analysis processes:
 * - CHECK_UNIQ_MAPQ
 * - FILTER_UNIQ_BAM
 * - EXTRACT_JUNCTIONS
 * - CLUSTER_JUNCTIONS
 * - COMPUTE_SUMMARY_STATS
 *
 * Used by: splicing_junction.nf, splicing_junction.sum_stat.nf
 */

process {

  withName: CHECK_UNIQ_MAPQ {
    cpus = 1
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }   // important: avoid sandbox extract killed
    time = { check_max( 1.h * task.attempt, 'time' ) }
  }

  withName: FILTER_UNIQ_BAM {
    cpus = 1
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    time = { check_max( 2.h * task.attempt, 'time' ) }
  }

  withName: EXTRACT_JUNCTIONS {
    cpus = 1
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }   // safe default
    time = { check_max( 6.h * task.attempt, 'time' ) }
  }

  withName: CLUSTER_JUNCTIONS {
    cpus = 1
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time = { check_max( 12.h * task.attempt, 'time' ) }
  }

  withName: COMPUTE_SUMMARY_STATS {
    cpus = 1
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    time = { check_max( 2.h * task.attempt, 'time' ) }
  }

}
